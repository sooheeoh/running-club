rules_version = '2';

// 한강런 클럽 — Storage 보안 규칙
// 사진 업로드: 인증된(익명 포함) 사용자만, 이미지 타입, 5MB 이하.
// 읽기: 사진은 공개 다운로드 URL(<img src>)로 로드되므로 공개 허용.

service firebase.storage {
  match /b/{bucket}/o {

    match /photos/{runId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }

    // 그 외 모든 경로는 거부.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
